PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=academic_portal

JWT_SECRET=change-me
JWT_EXPIRES_HOURS=12
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=academic-portal
JWT_AUDIENCE=academic-portal-web
COOKIE_SECURE=false
COOKIE_DOMAIN=

LDAP_MODE=mock
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=org
LDAP_USER_DN_TEMPLATE=uid={id},${LDAP_BASE_DN}
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

MOCK_LDAP_ACCEPT_ALL=true
MOCK_LDAP_PASSWORD=

RESET_TOKEN_EXPIRY_MINS=15
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_FORGOT_PWD=3

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@university.edu

AUDIT_ENCRYPTION_KEY=
AUDIT_LOG_RETENTION_DAYS=90

REDIS_URI=redis://localhost:6379
